local startTimeCrash = nil
function useShit()
    local tanks = game_api.getPartyUnitsByRole("TANK")
    if #tanks > 0 then
        local delaySettingTank = 300
        for _, tank in ipairs(tanks) do
            local totalCombatUnits = #state.getUnits
            local enemiesWithin10Yards = 0
            for _, unit in ipairs(state.getUnits) do
                if game_api.distanceBetweenUnits(tank, unit) <= 8 then 
                    enemiesWithin10Yards = enemiesWithin10Yards + 1
                end
                local percentageWithin10Yards = (enemiesWithin10Yards / totalCombatUnits) * 100
                if ((percentageWithin10Yards >= 75) ) and game_api.distanceBetweenUnits(tank, unit) < 5  then
                    if game_api.unitIsMoving(tank) then
                        startTimeCrash = state.currentTime
                    elseif startTimeCrash then
                        if state.currentTime - startTimeCrash >= delaySettingTank then
                            return true
                        end
                    end
                end
            end
        end
    elseif #tanks == 0 then
        return true 
    end
    return false
end



