function CombustionCooldowns()

    if state.FightRemains >= game_api.getSetting(settings.timeToDie) and game_api.currentPlayerAuraRemainingTime(auras.Combustion,true) > 6000 then
        local trinket1 = game_api.getTrinketID1()
        if trinket1 ~= nil then
            if (trinket1 == 193773) then
                if not game_api.isOnCooldown(trinket1) and (game_api.unitAuraRemainingTime(state.currentPlayer, 381955, true) > 0 or game_api.unitAuraRemainingTime(state.currentPlayer, 381957, true) > 0) and game_api.canCastObject(trinket1) and state.FightRemains > 10  then
                    print("Using Trinket 1")
                    game_api.castObject(trinket1)
                    return true
                end
            end
        end --381957 verse
        --381955 haste
        local trinket2 = game_api.getTrinketID2()
        if trinket2 ~= nil then
            if (trinket2 == 193773) then --spoils logic
                if not game_api.isOnCooldown(trinket2) and (game_api.unitAuraRemainingTime(state.currentPlayer, 381955, true) > 0 or game_api.unitAuraRemainingTime(state.currentPlayer, 381957, true) > 0) and game_api.canCastObject(trinket2) and state.FightRemains > 10  then
                    print("Using Trinket 2")
                    game_api.castObject(trinket2)
                    return true
                end
            end
        end
        if API.dpsTrinket(auras.Combustion,false) then
            return true
        end
    end
    if API.useRacialCommon() then
        return true
    end 
    return false

end

function ExecuteRemains(spell)
    if game_api.currentPlayerIsCasting() then
        if game_api.unitCastingSpellID(state.currentPlayer) == spell then
            return 100 - game_api.getCurrentPlayerCastPercentage()
        end
    end
    return 99999
end


