                if game_api.unitHasAura(unit, auraId, false) and not game_api.currentPlayerHasAura(auraId, false) and game_api.distanceToUnit(unit) < 40 then
                    print("Purging Enemy")
                    game_api.castSpellOnFocus(spells.SpellSteal, unit)
                    return true
                end
            end
        end
    end
    return false
end

function RemoveCurse()
    if CanCast(spells.RemoveCurse) and state.currentManaPercent > 25 then
        for _, unit in ipairs(state.getUnits) do
            for _, auraId in pairs(cLists.CurseList) do
                if game_api.unitHasAura(unit, auraId, false) and game_api.distanceToUnit(unit) < 40 then
                    print("Remove Curse Enemy")
                    game_api.castSpellOnFocus(spells.RemoveCurse, unit)
                    return true
                end
            end
        end
    end
    return false
end





--[[
    Run on eatch engine tick if game has focus and is not loading
]]
function OnUpdate()
    if not game_api.isSpec(137019) then
        API.Debug("Not Fire Spec")
        return
    end
    if game_api.getToggle("Pause") then
        return
    end

    StateUpdate()
    if game_api.currentPlayerIsMounted() or game_api.unitHealth(state.currentPlayer) <= 0 or game_api.unitChannelingSpellID(state.currentPlayer) == spells.ShiftingPower then
        return
    end
    if not game_api.unitInCombat(game_api.getCurrentPlayer()) and not game_api.objectIsOnCooldown(211495) and game_api.canCastObject(211495) and game_api.currentPlayerAuraRemainingTime(393438,false) < 300000 then
        print("Using Aug Rune")
        game_api.castObject(211495)
        return true
    end
    if state.StopCastLogic then
        game_api.stopCast()
        print("Stop Casting Logic")
        return true -- stop cast logic
    end
    if game_api.unitInCombat(state.currentPlayer) then
        if API.Interrupt("mage") then
            return true
        end
        if GreaterInvis() then
            return true
        end
        if game_api.getToggle(settings.dispel) then
            if SpellSteal() then
                return true
            end
            if RemoveCurse() then
                return true
            end
            if Affix(spells.RemoveCurse, spells.Polymorph) then
                return true
            end
        end
        if state.CombustionDown and not state.channeling then
            if useWeapon() then
                return true
            end
        end
        if Defense() then
            return true
        end
    end
    if not game_api.unitInCombat(state.currentPlayer) and CanCast(spells.BlazingBarrier)  and not state.HasDefensive   then
        game_api.castSpell(spells.BlazingBarrier)
        API.Debug("Blazing Barrier OOC")
        return true
    end
    -- Auto retarget
    if game_api.unitInCombat(state.currentPlayer) and game_api.getSetting(settings.autoRetarget) then
        if state.currentTarget == "00" or (game_api.unitHealthPercent(state.currentTarget) == 0 and state.currentTarget ~= "00") or not API.IsFacing(state.currentTarget) or not API.IsInRange(38,state.currentTarget) then
            local newTarget = UnitWithHighestHealth()
            if newTarget then
                print("Switching Target")
                game_api.setTarget(newTarget)
            end
        end
    end
    local engagementType = game_api.getSetting(settings.engagementType)
    if engagementType == "Player In Combat" then
        if game_api.unitInCombat(state.currentPlayer) and state.TargetCheck then
            if DPS() then
                return true
            end
        end
    end
    if engagementType == "Target In Combat" then
        if (API.isInCombatOrHasNpcId(state.currentTarget, cLists.npcIdList) or API.isUnitDummy(state.currentTarget)) and state.TargetCheck then
            if DPS() then
                return true
            end
        end
    end
    if game_api.canCast(spells.ArcaneIntellect) and not game_api.currentPlayerHasAura(auras.ArcaneIntellect,false) then
        API.Debug("Casting Arcane Intellect")
        game_api.castSpellOnTarget(spells.ArcaneIntellect,state.currentPlayer)
        return true
    end

end