local lastSpellCastTime = {}

function Affix(SpellForAfflicted, SpellForIncorporeal)
    -- Handle Afflicted units
    if (#state.afflictedUnits > 0) and (game_api.canCast(SpellForAfflicted) and game_api.hasTalent(talents.RemoveCurse)) then
        for _, unit in ipairs(state.afflictedUnits) do
            if (game_api.distanceToUnit(unit) < 40) and API.IsFacing(unit) and (game_api.unitIsCasting(unit) or game_api.unitIsChanneling(unit)) then
                if game_api.canCast(SpellForAfflicted) then
                    game_api.castSpellOnFocus(SpellForAfflicted, unit)
                    return true
                end
            end
        end
    end

    -- Handle Incorporeal units
    local count = 0
    local currentTime = game_api.currentTime()
    if (#state.incorporealUnits > 0) and game_api.canCast(SpellForIncorporeal) and not state.moving then
        for _, unit in ipairs(state.incorporealUnits) do
            for _, auraId in pairs(PolymorphAuras) do
                if game_api.unitHasAura(unit, auraId, true) then
                    count = count + 1
                end
            end
            if count < 1 and (game_api.distanceToUnit(unit) < 30) and game_api.isUnitHostile(unit, true) and
                (game_api.unitIsCasting(unit) or game_api.unitIsChanneling(unit)) and
                (not lastSpellCastTime[SpellForIncorporeal] or currentTime - lastSpellCastTime[SpellForIncorporeal] >= 2000) then
                if game_api.canCast(SpellForIncorporeal) then
                    game_api.castSpellOnFocus(SpellForIncorporeal, unit)
                    lastSpellCastTime[SpellForIncorporeal] = currentTime
                    print("Casting " .. SpellForIncorporeal)
                    return true
                end
            end
        end
    end

    return false
end


function GreaterInvis()
    if CanCast(spells.GreaterInvis) then
        local randomNumber = API.randomBetween(20, 60)
        for _, unit in ipairs(state.getUnits) do
            if game_api.isUnitHostile(unit, true) then
                if game_api.unitIsCasting(unit) and not game_api.unitIsChanneling(unit) then
                    unitCasting = true
                    castPercentage = game_api.unitCastPercentage(unit)
                end
                if game_api.unitIsChanneling(unit) then
                    unitCasting = true
                    castPercentage = game_api.unitChannelPercentage(unit)
                end
                local spellId = game_api.unitCastingSpellID(unit)
                local channelId = game_api.unitChannelingSpellID(unit)
                if unitCasting then
                    if castPercentage >= randomNumber and game_api.unitTarget(unit) == game_api.getCurrentPlayer() then
                        if cLists.shadowMeldTarget[spellId] or cLists.shadowMeldTarget[channelId] then
                            print("Using GreaterInvis to Ignore Targeted Cast")
                            game_api.castSpell(spells.GreaterInvis)
                        end
                    end
                end
            end
        end
    end
    return false
end


function UnitWithHighestHealth()
    local highestHealthUnit = nil
    local highestEffectiveHealth = 0 -- Initialize with 0 for comparison
    
    for _, unit in ipairs(state.getUnits) do
        local effectiveHealth = game_api.unitHealth(unit)
        if effectiveHealth > highestEffectiveHealth and API.IsInRange(40, unit) then
            highestEffectiveHealth = effectiveHealth
            highestHealthUnit = unit
        end
    end
    
    return highestHealthUnit
end

function CanCast(spell)
    if game_api.canCast(spell) and game_api.spellIsKnown(spell) and not game_api.isOnCooldown(spell) then
        if (state.casting and state.castingPercent > 90) or (state.castingPercent == 100 and not state.channeling) then
            return true
        end
        if (state.channeling and state.channelingPercent > 90) or (state.channelingPercent == 100 and not state.casting) then
            return true
        end
        if state.channelingPercent == 0 and state.castingPercent == 0 then
            return true
        end
    end
    return false
end


function CanCastCharges(spell,charge)
    if game_api.canCastCharge(spell,charge) and game_api.spellIsKnown(spell) then
        if (state.casting and state.castingPercent > 85) or (state.castingPercent == 100 and not state.channeling) then
            return true
        end
        if (state.channeling and state.channelingPercent > 90) or (state.channelingPercent == 100 and not state.casting) then
            return true
        end
        if state.channelingPercent == 0 and state.castingPercent == 0 then
            return true
        end
    end
    return false
end

local lastCastTime = {}

function CanCastOGCD(spell, charge)
    local currentTime = game_api.currentTime() 

    if game_api.spellIsKnown(spell) and game_api.getChargeCountOnCooldown(spell) ~= charge then
        -- Check if the spell has been cast within the last 500ms
        if not lastCastTime[spell] or (currentTime - lastCastTime[spell] >= 1000) then
            return true
        end
    end
    return false
end







function HasAnyTwoBuffs()
    local buffCount = 0
    local buffs = {390386, 80353, 2825, 32182, 264667, 381301, 390386, 10060,386540} 

    for _, buff in ipairs(buffs) do
        if game_api.currentPlayerHasAura(buff, false) then
            buffCount = buffCount + 1
            if buffCount >= 2 then
                return true, buffCount
            end
        end
    end

    return false, buffCount
end






function ScorchExecuteActive()
    if not game_api.hasTalentEntry(talents.Scorch) then return false end
    if game_api.currentPlayerHasAura(auras.HeatShimmerBuff,true) then return true end
    return game_api.unitHealthPercent(state.currentTarget) <= 30 + 5 * API.num(game_api.hasTalentEntry(talents.SunKingsBlessing))
end


function FirestarterActive()
    return (game_api.hasTalentEntry(talents.Firestarter) and game_api.unitHealthPercent(state.currentTarget) > 90)
end

function FirestarterRemains()
    return game_api.hasTalentEntry(talents.Firestarter) and ((game_api.unitHealthPercent(state.currentTarget) > 90) and API.TimeToX(state.currentTarget,90) or 0) or 0
end

function SearingTouchActive()
    return game_api.hasTalentEntry(talents.Scorch) and (game_api.unitHealthPercent(state.currentTarget) < 30)
end

function ImprovedScorchActive()
    return game_api.hasTalentEntry(talents.ImprovedScorch) and (game_api.unitHealthPercent(state.currentTarget) < 30)
end



function FreeCastAvailable()
    local FSInFlight = FirestarterActive() and (state.PyroblastInFlight + state.FireBallInFlight) or 0
    FSInFlight = FSInFlight + (state.PhoenixFlamesInFlight or state.lastCastPFCount)
    return state.HasHotStreak or game_api.currentPlayerHasAura(auras.Hyperthermia,true) or (state.HeatingUpBuff  and ((ImprovedScorchActive() and state.castingID == spells.Scorch) or (FirestarterActive() and ((state.castingID == state.Bolt) or FSInFlight > 0))))
end

function HotStreakInFlight()
    local total = 0
    if state.PhoenixFlamesInFlightBool or state.FireBallInFlightBool then
        total = total + 1
    end
    return total
end

